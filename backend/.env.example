# Backend (Go) — runtime config, loaded automatically via godotenv.
# Holds SECRETS (Shopify secret, DB password) that must NEVER reach the frontend bundle.
STAGE_STATUS=dev
SERVER_HOST=127.0.0.1
SERVER_PORT=5005
# Shopify app (server-side)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=
APP_URL=https://your-tunnel.example.dev
APP_API_VERSION=2025-07
# Database (must match docker-compose.yml)
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=app
DB_PASSWORD=app_pass
DB_NAME=announcement_bar
